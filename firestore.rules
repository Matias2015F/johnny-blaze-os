rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Datos de acceso/facturación — solo el propio usuario puede leer/escribir
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Datos del taller — colecciones de cada usuario (ordenes, clientes, motos, etc.)
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
