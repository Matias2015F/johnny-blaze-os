rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isPlatformAdmin() {
      return signedIn() && (
        request.auth.uid == "TNwwuKJsIXN29zJg8HWfORawdFm1" ||
        request.auth.token.email == "matias4604@gmail.com" ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == "admin" ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isPlatformAdmin == true
      );
    }

    // Campos de suscripción: solo el Admin SDK (webhook) puede modificarlos.
    // El cliente nunca puede autopromover su plan, extender activoHasta ni cambiar su rol.
    function noModificaCamposSuscripcion() {
      let protegidos = ['estado', 'activoHasta', 'plan', 'pagoEstado', 'rol',
                        'isPlatformAdmin', 'graceEndsAt', 'nextBillingAt',
                        'currentPlanKey', 'trialEndsAt', 'featureFlags', 'features'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(protegidos);
    }

    function perfilUsuarioInicialSeguro(uid) {
      let data = request.resource.data;
      return isOwner(uid) &&
        data.uid == uid &&
        data.rol != "admin" &&
        data.isPlatformAdmin != true &&
        (!('estado' in data) || data.estado == "trial") &&
        (!('plan' in data) || data.plan == "trial" || data.plan == "base") &&
        (!('pagoEstado' in data) || data.pagoEstado == "pendiente");
    }

    match /admin_settings/{docId} {
      // Cualquier usuario autenticado puede leer "global" (precios y config publica de planes).
      // Cualquier otro documento admin_settings requiere ser admin de plataforma.
      allow read: if isPlatformAdmin() || (signedIn() && docId == "global");
      allow write: if isPlatformAdmin();
    }

    match /telemetryEvents/{eventId} {
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.accountId == request.auth.uid;
      allow read: if isPlatformAdmin();
      allow update, delete: if isPlatformAdmin();
    }

    match /usageSnapshots/{snapshotId} {
      allow create, update: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.accountId == request.auth.uid;
      allow read: if isPlatformAdmin() || (
        signedIn() &&
        resource.data.uid == request.auth.uid
      );
      allow delete: if isPlatformAdmin();
    }

    match /billingInvoices/{invoiceId} {
      allow read: if isPlatformAdmin() || (
        signedIn() &&
        resource.data.uid == request.auth.uid
      );
      allow create, update, delete: if isPlatformAdmin();
    }

    match /billingEvents/{eventId} {
      allow read, write: if isPlatformAdmin();
    }

    match /soporteTickets/{ticketId} {
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow read: if isPlatformAdmin() || (
        signedIn() &&
        resource.data.uid == request.auth.uid
      );
      allow update, delete: if isPlatformAdmin();
    }

    // Datos del taller por usuario — aislados completamente.
    // El wildcard {document=**} cubre todas las colecciones del taller:
    // trabajos, presupuestos, clientes, motos, caja, config, catalogoTareas,
    // titularidades, precioHistorial, recordatorios, agendaTurnos, repuestosHistorial.
    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid) || isPlatformAdmin();
    }

    // Presupuestos: regla explícita para documentar la colección.
    // Cubierta por el wildcard anterior; se repite aquí por claridad.
    match /users/{uid}/presupuestos/{presId} {
      allow read, write: if isOwner(uid) || isPlatformAdmin();
    }

    // Perfil SaaS del usuario:
    // — Crear: el propio usuario puede crear su perfil inicial (estado trial).
    // — Actualizar: el usuario solo puede tocar campos no sensibles.
    //   Los campos de suscripción (estado, plan, activoHasta, etc.)
    //   solo los escribe el Admin SDK (webhook mp-webhook.js) desde el servidor.
    // — Eliminar: el usuario puede eliminar su propia cuenta.
    match /usuarios/{uid} {
      allow read: if isOwner(uid) || isPlatformAdmin();
      allow create: if perfilUsuarioInicialSeguro(uid) || isPlatformAdmin();
      allow update: if (isOwner(uid) && noModificaCamposSuscripcion()) || isPlatformAdmin();
      allow delete: if isOwner(uid) || isPlatformAdmin();
    }

    match /usuarios/{uid}/billingInvoices/{invoiceId} {
      allow read: if isPlatformAdmin() || isOwner(uid);
      allow create, update, delete: if isPlatformAdmin();
    }
  }
}
