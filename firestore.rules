rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isPlatformAdmin() {
      return signedIn() &&
        (
          request.auth.uid == "123456789" ||
          request.auth.token.email == "fefe@gmail.com"
        );
    }

    function sameUid(field) {
      return signedIn() && request.resource.data[field] == request.auth.uid;
    }

    // Perfil SaaS por cuenta
    match /accounts/{uid} {
      allow read: if isOwner(uid) || isPlatformAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    // Reglas globales del producto
    match /adminSettings/{docId} {
      allow read: if signedIn();
      allow write: if isPlatformAdmin();
    }

    // Telemetría cruda
    match /telemetryEvents/{eventId} {
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.accountId == request.auth.uid;
      allow read: if isPlatformAdmin();
      allow update, delete: if isPlatformAdmin();
    }

    // Snapshots agregados de uso
    match /usageSnapshots/{snapshotId} {
      allow create, update: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.accountId == request.auth.uid;
      allow read: if isPlatformAdmin() || (
        signedIn() &&
        resource.data.uid == request.auth.uid
      );
      allow delete: if isPlatformAdmin();
    }

    // Facturación SaaS
    match /billingInvoices/{invoiceId} {
      allow read: if isPlatformAdmin() || (
        signedIn() &&
        resource.data.uid == request.auth.uid
      );
      allow create, update, delete: if isPlatformAdmin();
    }

    match /billingEvents/{eventId} {
      allow read, write: if isPlatformAdmin();
    }

    // Datos del taller y subcolecciones por usuario
    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid) || isPlatformAdmin();
    }

    // Compatibilidad legacy
    match /usuarios/{uid} {
      allow read, write: if isOwner(uid) || isPlatformAdmin();
    }

    // Lectura temporal para migración legacy
    match /ordenes/{doc} { allow read: if signedIn(); }
    match /clientes/{doc} { allow read: if signedIn(); }
    match /motos/{doc} { allow read: if signedIn(); }
    match /caja/{doc} { allow read: if signedIn(); }
    match /config/{doc} { allow read: if signedIn(); }
    match /serviciosCatalogo/{doc} { allow read: if signedIn(); }
  }
}
