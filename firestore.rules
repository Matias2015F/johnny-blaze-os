rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Datos de acceso/facturación — solo el propio usuario puede leer/escribir
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Datos del taller y snapshots/backups — solo el propio usuario
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Lectura temporal para migración de colecciones raíz legacy
    match /ordenes/{doc} { allow read: if request.auth != null; }
    match /clientes/{doc} { allow read: if request.auth != null; }
    match /motos/{doc} { allow read: if request.auth != null; }
    match /caja/{doc} { allow read: if request.auth != null; }
    match /config/{doc} { allow read: if request.auth != null; }
    match /serviciosCatalogo/{doc} { allow read: if request.auth != null; }
  }
}
